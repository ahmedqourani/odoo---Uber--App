<odoo>

    <!-- ========================= RIDE ========================= -->

    <record id="view_ride_list" model="ir.ui.view">
        <field name="name">uber.ride.list</field>
        <field name="model">uber.ride</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="passenger_id"/>
                <field name="driver_id"/>
                <field name="pickup"/>
                <field name="destination"/>
                <field name="fare"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <record id="view_ride_form" model="ir.ui.view">
        <field name="name">uber.ride.form</field>
        <field name="model">uber.ride</field>
        <field name="arch" type="xml">
            <form>
                <header>

                    <button name="action_confirm_ride"
                            string="Confirm Ride"
                            type="object"
                            class="btn-primary"
                            invisible="status != 'pending'"/>

                    <button name="action_complete_ride"
                            string="Complete Ride"
                            type="object"
                            class="btn-success"
                            invisible="status != 'accepted'"/>

                    <button name="action_view_payment"
                            string="View Payment"
                            type="object"
                            class="btn-info"
                            invisible="not payment_id"/>

                    <field name="status" widget="statusbar"
                           statusbar_visible="pending,accepted,done"/>

                </header>

                <sheet>
                    <group>
                        <field name="passenger_id" required="1"/>
                        <field name="driver_id"/>
                    </group>

                    <group>
                        <field name="pickup" required="1"/>
                        <field name="destination" required="1"/>
                        <field name="fare" readonly="1"/>
                        <field name="url" widget="url"/>
                        <field name="payment_id" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_ride_search" model="ir.ui.view">
        <field name="name">uber.ride.search</field>
        <field name="model">uber.ride</field>
        <field name="arch" type="xml">
            <search>
                <field name="pickup"/>
                <field name="destination"/>
                <field name="passenger_id"/>
                <field name="driver_id"/>

                <filter name="pending" string="Pending" domain="[('status','=','pending')]"/>
                <filter name="accepted" string="Accepted" domain="[('status','=','accepted')]"/>
                <filter name="done" string="Done" domain="[('status','=','done')]"/>
            </search>
        </field>
    </record>

    <!-- ========================= PASSENGER ========================= -->

    <record id="view_passenger_list" model="ir.ui.view">
        <field name="name">uber.passenger.list</field>
        <field name="model">uber.passenger</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="ride_count"/>
            </tree>
        </field>
    </record>

    <record id="view_passenger_form" model="ir.ui.view">
        <field name="name">uber.passenger.form</field>
        <field name="model">uber.passenger</field>
        <field name="arch" type="xml">
            <form>

                <header>
                    <button name="action_check_phone"
                            string="Check Phone"
                            type="object"
                            class="btn-primary"/>
                </header>

                <sheet>
                    <group>
                        <field name="name" required="1"/>
                        <field name="phone" required="1"/>
                        <field name="email" required="1"/>
                        <field name="ride_count" readonly="1"/>
                    </group>

                    <notebook>
                        <page string="Rides">
                            <field name="rides_ids"/>
                        </page>
                    </notebook>
                </sheet>

            </form>
        </field>
    </record>

    <record id="view_passenger_search" model="ir.ui.view">
        <field name="name">uber.passenger.search</field>
        <field name="model">uber.passenger</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="phone"/>
                <field name="email"/>
            </search>
        </field>
    </record>

    <!-- ========================= DRIVER ========================= -->

    <record id="view_driver_list" model="ir.ui.view">
        <field name="name">uber.driver.list</field>
        <field name="model">uber.driver</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="vehicle"/>
                <field name="ride_count"/>
            </tree>
        </field>
    </record>

    <record id="view_driver_form" model="ir.ui.view">
        <field name="name">uber.driver.form</field>
        <field name="model">uber.driver</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <group>
                        <field name="name" required="1"/>
                        <field name="phone" required="1"/>
                        <field name="email" required="1"/>
                        <field name="vehicle" required="1"/>
                        <field name="ride_count" readonly="1"/>
                    </group>

                    <notebook>
                        <page string="Rides">
                            <field name="rides_ids"/>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <record id="view_driver_search" model="ir.ui.view">
        <field name="name">uber.driver.search</field>
        <field name="model">uber.driver</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="vehicle"/>
                <field name="email"/>
            </search>
        </field>
    </record>

    <!-- ========================= PAYMENT ========================= -->

    <record id="view_payment_list" model="ir.ui.view">
        <field name="name">uber.payment.list</field>
        <field name="model">uber.payment</field>
        <field name="arch" type="xml">
            <tree>
                <field name="ride_id"/>
                <field name="amount"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <record id="view_payment_form" model="ir.ui.view">
        <field name="name">uber.payment.form</field>
        <field name="model">uber.payment</field>
        <field name="arch" type="xml">
            <form>

                <header>
                    <button name="action_pay"
                            string="Pay"
                            type="object"
                            class="btn-success"
                            invisible="status == 'paid'"/>

                    <field name="status"
                           widget="statusbar"
                           statusbar_visible="draft,paid"/>
                </header>

                <sheet>
                    <group>
                        <field name="ride_id" required="1"/>
                        <field name="amount"/>
                    </group>
                </sheet>

            </form>
        </field>
    </record>

    <record id="view_payment_search" model="ir.ui.view">
        <field name="name">uber.payment.search</field>
        <field name="model">uber.payment</field>
        <field name="arch" type="xml">
            <search>
                <field name="ride_id"/>
                <field name="status"/>
            </search>
        </field>
    </record>

    <!-- ========================= ACTIONS ========================= -->

    <record id="action_ride" model="ir.actions.act_window">
        <field name="name">Rides</field>
        <field name="res_model">uber.ride</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_ride_search"/>
    </record>

    <record id="action_passenger" model="ir.actions.act_window">
        <field name="name">Passengers</field>
        <field name="res_model">uber.passenger</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_passenger_search"/>
    </record>

    <record id="action_driver" model="ir.actions.act_window">
        <field name="name">Drivers</field>
        <field name="res_model">uber.driver</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_driver_search"/>
    </record>

    <record id="action_payment" model="ir.actions.act_window">
        <field name="name">Payments</field>
        <field name="res_model">uber.payment</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_payment_search"/>
    </record>

    <!-- ========================= MENUS ========================= -->

    <menuitem id="menu_uber_root" name="Uber App"/>

    <menuitem id="menu_ride"
              name="Rides"
              parent="menu_uber_root"
              action="action_ride"/>

    <menuitem id="menu_passenger"
              name="Passengers"
              parent="menu_uber_root"
              action="action_passenger"/>

    <menuitem id="menu_driver"
              name="Drivers"
              parent="menu_uber_root"
              action="action_driver"/>

    <menuitem id="menu_payment"
              name="Payments"
              parent="menu_uber_root"
              action="action_payment"/>

</odoo>